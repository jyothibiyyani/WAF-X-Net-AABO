# =========================================================

IMG_SIZE = (224, 224)
BATCH_SIZE = 16
MAX_FRAMES = 30
WARMUP_EPOCHS = 5
SOURCE_FULL_EPOCHS = 35

SEEDS = [42, 123]

FFPP_REAL_VIDEOS = 500
FFPP_FAKE_VIDEOS = 500

FINE_TUNE_RATIO = 0.10
FINE_TUNE_EPOCHS = 10

